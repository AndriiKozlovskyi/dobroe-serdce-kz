"services__request":272,"about__heart_image":273,"about__years_label":277,"contacts__subtitle":278,"documents__clarify":279,"documents__eyebrow":62,"footer__hours_text":280,"services__cta_text":281,"services__subtitle":282,"about__cta_services":271,"contacts__map_title":283,"documents__subtitle":284,"footer__description":285,"footer__hours_title":286,"gallery__image_alts":287,"gallery__open_photo":304,"gallery__title_blue":305,"gallery__title_gold":306,"header__call_button":107,"hero__cta_secondary":307,"reviews__link_label":308,"reviews__title_blue":309,"reviews__title_gold":310,"seo__default__title":311,"services__cta_badge":312,"services__cta_title":313,"contacts__hours_hint":314,"contacts__hours_main":315,"contacts__phone_hint":316,"contacts__title_blue":317,"contacts__title_gold":318,"documents__positions":319,"price__factor_labels":320,"services__title_blue":333,"services__title_gold":334,"about__badge_subtitle":335,"app__back_to_top_aria":336,"documents__list_title":337,"documents__title_blue":338,"documents__title_gold":339,"accommodation__eyebrow":340,"accommodation__options":341,"contacts__address_city":363,"footer__contacts_title":70,"footer__made_with_care":364,"header__open_menu_aria":365,"seo__default__keywords":366,"accommodation__accepted":367,"reviews__platform_label":389,"contacts__address_street":110,"documents__transfer_text":390,"header__mobile_menu_aria":391,"hero__scroll_button_aria":392,"accommodation__title_blue":393,"accommodation__title_gold":394,"documents__transfer_badge":395,"documents__transfer_title":396,"seo__default__description":397,"accommodation__blocked_note":398,"accommodation__not_accepted":399,"accommodation__blocked_title":412,"accommodation__accepted_title":413,"accommodation__blocked_subtitle":414,"accommodation__accepted_subtitle":415},"baff7881-4471-49ae-b161-53feab63e6fd","site_content",[14,19,23,27,31,35,39],{"a":15,"q":16,"_uid":17,"component":18},"«Доброе сердце» — частный дом престарелых в Астане. Мы обеспечиваем круглосуточный квалифицированный уход, медицинскую поддержку и 4-разовое питание для пожилых людей. Адрес: просп. Республики, Астана.","Что такое пансионат «Доброе сердце» и где он находится?","mg0a30zn6hifufp7b5j8kt","qa_item",{"a":20,"q":21,"_uid":22,"component":18},"В стоимость входят: еженедельный медицинский осмотр, круглосуточное дежурство медсестры, 4-разовое сбалансированное питание, ежедневные прогулки, контроль приёма лекарств, гигиенические процедуры, психологическая поддержка и онлайн-встречи с родными.","Какие услуги включены в проживание?","bd158rh3tfuvx7iwuowti",{"a":24,"q":25,"_uid":26,"component":18},"Мы принимаем здоровых пожилых людей, лежачих больных, людей с деменцией и болезнью Альцгеймера, после инсульта, инфаркта, операций и переломов (в т.ч. шейки бедра). Противопоказания: 4-я стадия онкологии, гепатит B\u002FC, инфекционные заболевания, выраженная агрессия.","Кого вы принимаете в пансионат?","tgzr5ksj9xpr7xdcgn3ohd",{"a":28,"q":29,"_uid":30,"component":18},"Стоимость рассчитывается индивидуально с учётом состояния здоровья, формата размещения и объёма ухода. Позвоните нам по номеру +38 096 146 29 10 — рассчитаем стоимость персонально для вашей ситуации.","Сколько стоит проживание в пансионате в Астане?","7tx24a8ex5i6zk42e1p2t9",{"a":32,"q":33,"_uid":34,"component":18},"Необходимы: ксерокопии паспортов (родственника и проживающего), письменное согласие проживающего, медицинская карта со справками, справка от психиатра (при необходимости). Если есть вопросы — звоните, мы поможем.","Какие документы нужны для поступления?","cno853ztm5dbfrndu6wr",{"a":36,"q":37,"_uid":38,"component":18},"Да, предлагаем три формата: кратковременное (посуточно или на любой срок), дневное (днём у нас, ночью дома) и постоянное круглосуточное размещение. Подберём удобный вариант для вашей семьи.","Есть ли дневное или кратковременное размещение?","6jkhrrld143tuo076kahp",{"a":40,"q":41,"_uid":42,"component":18},"Да, организуем индивидуальную доставку проживающего прямо в пансионат. Учитываем состояние здоровья, обеспечиваем комфортный транспорт и сопровождение. Работаем по Астане и области.","Вы организуете трансфер до пансионата?","kclcqh3a76rbqiv8f2csv","Главный баннер","Узнать цену",[46,51,55,59,63,67],{"_uid":47,"href":48,"label":49,"component":50},"nkkdngf4rrqnq5ptc1gx","#about","О нас","link_item",{"_uid":52,"href":53,"label":54,"component":50},"xle3skmlxmf4ifz1u4u5p","#services","Услуги",{"_uid":56,"href":57,"label":58,"component":50},"eehrvh60z0g6vmu7zotr9k","#accommodation","Проживание",{"_uid":60,"href":61,"label":62,"component":50},"g6sjiifvw78bbljtajewed","#documents","Документы",{"_uid":64,"href":65,"label":66,"component":50},"8wcr3d2zq1jpc9h93xpzq","#price","Цена",{"_uid":68,"href":69,"label":70,"component":50},"ma99p5w179n0kyvoqhjzkg","#contacts","Контакты",[72,74,76,78,80,82],{"_uid":73,"href":48,"label":49,"component":50},"rnzv7b0sbukv4jgmoec9xg",{"_uid":75,"href":53,"label":54,"component":50},"q2ezu30qdpavqxgm865ep",{"_uid":77,"href":57,"label":58,"component":50},"cf0i5biuajdaw7j67ewhde",{"_uid":79,"href":61,"label":62,"component":50},"1b4virsqendppkpj2317km",{"_uid":81,"href":65,"label":66,"component":50},"9avvb561nfjeudpfxja3nh",{"_uid":83,"href":69,"label":70,"component":50},"5ooqee588hlxkn5g0mr8la","Выбирая пансионат для пожилых людей, важно найти место, где царит настоящая забота. В «Добром сердце» мы ставим человека на первое место.","Чтобы изменить своё восприятие дома для пожилых людей, мы приглашаем посетить пансионат лично и пообщаться с проживающими и персоналом.","Часто задаваемые вопросы","🇰🇿 Казахстан, г. Астана",[89,93,96,99],{"_uid":90,"text":91,"component":92},"n82mgdqd7u9l94kp95mtf","Позвоните нам","text_item",{"_uid":94,"text":95,"component":92},"itoogycmeyip7u0an9qkes","Узнайте о наличии свободных мест",{"_uid":97,"text":98,"component":92},"dedb6cbm5xm2kwqzgnald","Обсудите индивидуальные условия проживания",{"_uid":100,"text":101,"component":92},"fdhx77elzd1dpuguui4e5","Подпишите договор и оформите документы","Открыть больше отзывов","Самые важные вопросы о проживании в пансионате — честно и подробно.","Следующее фото","Предыдущее фото","Актуальные оценки и отзывы","Позвонить","Пансионат «Доброе сердце». Все права защищены.","Сейчас принимаем заявки","просп. Республики","Закрыть","Наш пансионат для пожилых людей в Астане — место, где каждый проживающий чувствует себя дома: тёплая атмосфера, специалисты рядом и полноценная активная жизнь под заботливым присмотром.","Связаться с нами",[115,118,121],{"_uid":116,"text":117,"component":92},"wy1pbaruwyi74mfk06xw7k","Обеспечить качественный квалифицированный уход за каждым проживающим",{"_uid":119,"text":120,"component":92},"bvr7deo6cwkz5ms4tksz9","Создать благоприятную атмосферу для проживания и досуга",{"_uid":122,"text":123,"component":92},"glgeoqlxb3il2npdf740eb","Уделить каждому человеку внимание, выслушать его, окружить заботой","Часы работы","Телефон","Ответы на","ваши вопросы","Пансионат для пожилых людей",[130,141,148,155,162,169,176,183],{"alt":131,"src":132,"_uid":139,"component":140},"Зелёный двор и фасад пансионата с колоннами",{"id":133,"alt":134,"name":135,"focus":134,"title":134,"filename":136,"copyright":134,"fieldtype":137,"is_external_url":138},182924535437703,"","img.webp","https:\u002F\u002Fs3.amazonaws.com\u002Fa.storyblok.com\u002Ff\u002F292836177534295\u002F210766\u002F1a07daceb3\u002Fimg.webp","asset",false,"la7kro7zjemg698zhw7ai9","image_item",{"alt":142,"src":143,"_uid":147,"component":140},"Фасад здания пансионата с открытой террасой",{"id":144,"alt":134,"name":145,"focus":134,"title":134,"filename":146,"copyright":134,"fieldtype":137,"is_external_url":138},182924537973128,"img1.webp","https:\u002F\u002Fs3.amazonaws.com\u002Fa.storyblok.com\u002Ff\u002F292836177534295\u002F319584\u002F6fc915f115\u002Fimg1.webp","to3nbegqicaipxxr016o6c",{"alt":149,"src":150,"_uid":154,"component":140},"Просторная спальня с хрустальной люстрой",{"id":151,"alt":134,"name":152,"focus":134,"title":134,"filename":153,"copyright":134,"fieldtype":137,"is_external_url":138},182924540565897,"img2.webp","https:\u002F\u002Fs3.amazonaws.com\u002Fa.storyblok.com\u002Ff\u002F292836177534295\u002F133856\u002F0d92004f8d\u002Fimg2.webp","1yx4xpyzt9tokklmte2bk",{"alt":156,"src":157,"_uid":161,"component":140},"Входной зал пансионата с люстрой и диваном",{"id":158,"alt":134,"name":159,"focus":134,"title":134,"filename":160,"copyright":134,"fieldtype":137,"is_external_url":138},182924543043978,"img3.webp","https:\u002F\u002Fs3.amazonaws.com\u002Fa.storyblok.com\u002Ff\u002F292836177534295\u002F120202\u002Ffb8bc0487f\u002Fimg3.webp","bw6nvpv7mhc2icb1fbdmh9",{"alt":163,"src":164,"_uid":168,"component":140},"Уютная спальня с камином и кожаными креслами",{"id":165,"alt":134,"name":166,"focus":134,"title":134,"filename":167,"copyright":134,"fieldtype":137,"is_external_url":138},182924545427851,"img4.webp","https:\u002F\u002Fs3.amazonaws.com\u002Fa.storyblok.com\u002Ff\u002F292836177534295\u002F179728\u002Ffdbdd8e407\u002Fimg4.webp","w4vikb154ny5zkwxpffu",{"alt":170,"src":171,"_uid":175,"component":140},"Просторная кухня-столовая с большим обеденным столом",{"id":172,"alt":134,"name":173,"focus":134,"title":134,"filename":174,"copyright":134,"fieldtype":137,"is_external_url":138},182924547987852,"img5.webp","https:\u002F\u002Fs3.amazonaws.com\u002Fa.storyblok.com\u002Ff\u002F292836177534295\u002F177510\u002F0fa81f8870\u002Fimg5.webp","5e78b19z99du8p8sdou5ch",{"alt":177,"src":178,"_uid":182,"component":140},"Светлая комната с паркетом и белой мебелью",{"id":179,"alt":134,"name":180,"focus":134,"title":134,"filename":181,"copyright":134,"fieldtype":137,"is_external_url":138},182924550498701,"img6.webp","https:\u002F\u002Fs3.amazonaws.com\u002Fa.storyblok.com\u002Ff\u002F292836177534295\u002F132968\u002Ff7a87670c0\u002Fimg6.webp","oo5dpg63sqsjp5se3bvywc",{"alt":184,"src":185,"_uid":189,"component":140},"Санузел с мраморной плиткой и джакузи",{"id":186,"alt":134,"name":187,"focus":134,"title":134,"filename":188,"copyright":134,"fieldtype":137,"is_external_url":138},182924553238926,"img7.webp","https:\u002F\u002Fs3.amazonaws.com\u002Fa.storyblok.com\u002Ff\u002F292836177534295\u002F234648\u002F046b2ef5c3\u002Fimg7.webp","v3kfwi17u2dsg2b53uj0l","Индивидуально","Стоимость определяется индивидуально с учётом продолжительности проживания, состояния здоровья проживающего и категории номера. Чтобы записаться, необходимо позвонить и узнать о наличии свободных мест.","Круглосуточная поддержка","Индивидуальный подход",[195,200,204,208,212,216,220,224],{"_uid":196,"title":197,"component":198,"description":199},"n1tgf3211nm2p4oemy3pdp","Медицинский уход","service_item","Еженедельно проводится медицинский осмотр. Ежедневно измеряется давление, пульс и температура тела каждого проживающего.",{"_uid":201,"title":202,"component":198,"description":203},"f88mjsgb7v6axel3a6zcc9","Круглосуточная медсестра","Сиделки обеспечивают круглосуточное наблюдение. Медицинский пост для оказания экстренной помощи.",{"_uid":205,"title":206,"component":198,"description":207},"zqi2w3pelokcfjfytmdaa","Сбалансированное питание","Пятиразовое питание с учётом диетических требований и индивидуальных предпочтений каждого проживающего.",{"_uid":209,"title":210,"component":198,"description":211},"a5j1qfrg4mjplpx6v6pykd","Ежедневные прогулки","Ежедневные прогулки на открытом воздухе в сопровождении персонала для поддержания активности и хорошего настроения.",{"_uid":213,"title":214,"component":198,"description":215},"s2ut8p9n5a3eq7oe8e8ab","Контроль приёма лекарств","Своевременная выдача и ежедневный контроль приёма назначенных врачом медикаментов.",{"_uid":217,"title":218,"component":198,"description":219},"jo4ok5hmq29nai0iiudbh","Онлайн-встречи с родными","Организуем видеозвонки с родственниками через Skype, Viber, Facebook Messenger.",{"_uid":221,"title":222,"component":198,"description":223},"yp64e4niftbdceg78wuxjk","Гигиенический уход","Проведение гигиенических процедур, помощь при передвижении, кормление лежачих больных квалифицированным персоналом.",{"_uid":225,"title":226,"component":198,"description":227},"ni5t9qe0goj8c8o80knbwt","Индивидуальное внимание","Постоянный контроль за здоровьем, психологическая поддержка и индивидуальный подход к каждому проживающему.","Бережное сопровождение","Комфортный транспорт","По Астане и области",[232,235,238,241],{"_uid":233,"text":234,"component":92},"jigtnpjb3jmln9f5o0qa6r","Ксерокопии паспортов (родственника, заключающего договор, и будущего проживающего)",{"_uid":236,"text":237,"component":92},"wv8rryhw0z9lmk940jn4k","Письменное согласие будущего проживающего на размещение",{"_uid":239,"text":240,"component":92},"da3i8lj5niqy9o6obj6fi","Медицинская карта с имеющимися справками и заключениями врачей",{"_uid":242,"text":243,"component":92},"817po30l74jktaoxxmxj2q","Справка от психиатра (при необходимости)","Фотогалерея","Главная навигация","Питание в день","Круглосуточный уход","Частный пансионат","Доброе Сердце","Стоимость проживания в пансионате «Доброе сердце» рассчитывается персонально для каждого проживающего с учётом состояния здоровья, формата размещения и объёма необходимого ухода.","Отзывы",{"id":253,"alt":134,"name":254,"focus":134,"title":134,"filename":255,"copyright":134,"fieldtype":137,"is_external_url":138},182924524427652,"care.webp","https:\u002F\u002Fs3.amazonaws.com\u002Fa.storyblok.com\u002Ff\u002F292836177534295\u002F176918\u002F11e364ead5\u002Fcare.webp",{"id":257,"alt":134,"name":258,"focus":134,"title":134,"filename":259,"copyright":134,"fieldtype":137,"is_external_url":138},182924529834373,"hugs.webp","https:\u002F\u002Fs3.amazonaws.com\u002Fa.storyblok.com\u002Ff\u002F292836177534295\u002F221774\u002F47395d29cc\u002Fhugs.webp","Наша миссия","— ваш покой и благополучие","Адрес","Навигация","Записаться в пансионат","Листайте","Индивидуальный расчёт","Стоимость проживания","Прозрачное ценообразование","для каждой семьи","Посмотрите отзывы о пансионате на независимых площадках и оцените впечатления семей, которые уже выбрали нас.","Наши услуги","Оставить заявку",{"id":274,"alt":134,"name":275,"focus":134,"title":134,"filename":276,"copyright":134,"fieldtype":137,"is_external_url":138},182924532914566,"heart.webp","https:\u002F\u002Fs3.amazonaws.com\u002Fa.storyblok.com\u002Ff\u002F292836177534295\u002F256556\u002F272ebcce6c\u002Fheart.webp","Лет опыта","Позвоните или заполните форму — мы ответим как можно скорее и поможем подобрать лучший вариант для ваших близких.","Уточнить","Круглосуточно, 7 дней в неделю","Позвоните или оставьте заявку — наш консультант ответит на все ваши вопросы.","Наш пансионат обеспечивает благоприятные условия для проживания пожилых людей и ведения ими активного образа жизни и полноценного отдыха.","Расположение пансионата Доброе сердце","Для того чтобы поступить в пансионат, необходимо подготовить следующий перечень документов. Если у вас возникнут вопросы — позвоните нам, и мы поможем со всеми нюансами.","Частный комфортабельный пансионат «Доброе сердце» обеспечивает круглосуточный квалифицированный уход за пожилыми людьми в Астане с индивидуальным подходом к каждому проживающему.","Режим работы:",[288,290,292,294,296,298,300,302],{"_uid":289,"text":131,"component":92},"st84cerc2tkddylmv0b817",{"_uid":291,"text":142,"component":92},"kfyiz2oexd03xrbfbe7z9y",{"_uid":293,"text":149,"component":92},"zo6klzete6b4gdesqi97bc",{"_uid":295,"text":156,"component":92},"636aj4jjdjbf20jycq7vhd",{"_uid":297,"text":163,"component":92},"9syry0rjbu87ke95j43b7",{"_uid":299,"text":170,"component":92},"6e6cipqszc3xd89v81tidb",{"_uid":301,"text":177,"component":92},"ckpa8x0gz1ofeim4fw8rx5",{"_uid":303,"text":184,"component":92},"znwb2ei3lvkj6ox0uegnce","Просмотреть фото:","Взгляните на наш","уютный пансионат","Узнать больше","Смотреть","Нам доверяют","родные и близкие","Пансионат для пожилых людей в Астане | Дом престарелых «Доброе сердце»","Бесплатно","Есть вопросы об услугах?","Круглосуточный режим работы","Ежедневно, 24 \u002F 7","Круглосуточно, без выходных","Свяжитесь с нами","сегодня","позиций",[321,324,327,330],{"_uid":322,"text":323,"component":92},"9wrshjxxbh7n9rc9pmhfk","Продолжительность проживания",{"_uid":325,"text":326,"component":92},"ci9tx98p4mgh80nejv0mxl","Состояние здоровья проживающего",{"_uid":328,"text":329,"component":92},"0pwvb45njbvp6xgbw78y0z","Категория номера проживания",{"_uid":331,"text":332,"component":92},"h3lspu949u8f44d5y7f27c","Объём необходимого ухода","Комплексный уход","за вашими близкими","с заботой и любовью","Наверх","Перечень документов","Необходимые документы","для поступления","Варианты проживания",[342,348,353,358],{"_uid":343,"title":344,"subtitle":345,"component":346,"description":347},"2zv96irn6zt1ab3x5t8hed","Кратковременное размещение","Посуточно или на любой срок","accommodation_option","Вы можете разместить своих близких посуточно или на любой удобный для вас срок. Идеально для отдыха или командировки.",{"_uid":349,"title":350,"subtitle":351,"component":346,"description":352},"req8i4axl85n1h62sx86v","Дневное размещение","Днём здесь, ночью — дома","При необходимости вы можете разместить своего близкого на дневное время, а на ночь забрать домой.",{"_uid":354,"title":355,"subtitle":356,"component":346,"description":357},"e0fdfxm1qbm3gxmvuwlmbk","Круглосуточное размещение","Полный квалифицированный уход","Если у вас нет возможности обеспечить близким квалифицированный уход, мы возьмём эту обязанность на себя круглосуточно.",{"_uid":359,"title":360,"subtitle":361,"component":346,"description":362},"og6fjsrr6yztxzqd8yq8","Круглосуточный уход за больными и людьми с инвалидностью","Уход за лежачими больными и людьми с деменцией","Круглосуточный уход квалифицированной медсестры и няни: кормление, проведение гигиенических процедур, помощь при передвижении, сопровождение на прогулку.","Казахстан, г. Астана","Создано с заботой и любовью к людям","Открыть меню","пансионат для пожилых людей Астана, дом престарелых Астана, пансионат Астана, уход за пожилыми Астана, дом престарелых, пансионат для пожилых, круглосуточный уход за пожилыми, уход за лежачими больными, уход при деменции, болезнь Альцгеймера уход, реабилитация после инсульта, реабилитация после перелома шейки бедра, медицинский уход пожилые, сиделка круглосуточно, Доброе сердце Астана, пансионат Казахстан",[368,371,374,377,380,383,386],{"_uid":369,"text":370,"component":92},"g4l5aik3a4j543ln1u7rwd","Здоровые пожилые люди",{"_uid":372,"text":373,"component":92},"fixuv2yj9qnnjappczfh7","Лежачие больные пожилого возраста",{"_uid":375,"text":376,"component":92},"9dindpx40wsb9g0avmr8f","Люди после травм и переломов (в т.ч. перелома шейки бедра)",{"_uid":378,"text":379,"component":92},"hflxzcys5htex7umwjazq6","Люди, перенёсшие инсульт или инфаркт",{"_uid":381,"text":382,"component":92},"8cndi13n7cduqnnw72opm","Люди с болезнью Альцгеймера",{"_uid":384,"text":385,"component":92},"rem7abp19fi24zk2lfhix2","Пожилые люди со старческой деменцией",{"_uid":387,"text":388,"component":92},"r09gzu2kt9a6v2djk77juh","Пожилые люди после операций","Платформа","При необходимости организуем безопасную и комфортную доставку постояльца прямо в пансионат. Учитываем состояние здоровья, подбираем удобный маршрут и сопровождаем на каждом этапе поездки.","Мобильное меню","Прокрутить вниз","Выберите удобный","формат проживания","24\u002F7 поддержка","Индивидуальный трансфер","«Доброе сердце» — частный дом престарелых в Астане. Круглосуточный уход, медицинская помощь, 4-разовое питание. Пансионат для пожилых людей Астана — комфорт и профессиональная забота. Принимаем лежачих, с деменцией, после инсульта.","* К сожалению, мы не в состоянии предоставить специализированную помощь в перечисленных случаях. Для уточнения — звоните нам.",[400,403,406,409],{"_uid":401,"text":402,"component":92},"ai7q6xtwisqm7lst5n34","4-я стадия онкологического заболевания",{"_uid":404,"text":405,"component":92},"8qllm88cpdkxp86hrsmg6h","Гепатит B или C",{"_uid":407,"text":408,"component":92},"c6xcwao04dhsqcbxtjb6","Инфекционные заболевания",{"_uid":410,"text":411,"component":92},"xfu48iuaypk4tlaa4z6214","Выраженное агрессивное поведение","Противопоказания","Кого мы принимаем","Случаи, требующие специализированной помощи","Полный перечень состояний и диагнозов","ru",null,-10,[],0,"43e95694-9ba3-4771-87c4-5dc1e66fbca2","2026-06-01T21:59:47.547Z","default",[],1780587824081]