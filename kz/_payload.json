"services__request":272,"about__heart_image":273,"about__years_label":277,"contacts__subtitle":278,"documents__clarify":279,"documents__eyebrow":62,"footer__hours_text":280,"services__cta_text":281,"services__subtitle":282,"about__cta_services":271,"contacts__map_title":283,"documents__subtitle":284,"footer__description":285,"footer__hours_title":286,"gallery__image_alts":287,"gallery__open_photo":304,"gallery__title_blue":305,"gallery__title_gold":306,"header__call_button":107,"hero__cta_secondary":307,"reviews__link_label":308,"reviews__title_blue":309,"reviews__title_gold":310,"seo__default__title":311,"services__cta_badge":312,"services__cta_title":313,"contacts__hours_hint":314,"contacts__hours_main":315,"contacts__phone_hint":316,"contacts__title_blue":317,"contacts__title_gold":318,"documents__positions":319,"price__factor_labels":320,"services__title_blue":333,"services__title_gold":249,"about__badge_subtitle":334,"app__back_to_top_aria":335,"documents__list_title":336,"documents__title_blue":337,"documents__title_gold":338,"accommodation__eyebrow":339,"accommodation__options":340,"contacts__address_city":362,"footer__contacts_title":70,"footer__made_with_care":363,"header__open_menu_aria":364,"seo__default__keywords":365,"accommodation__accepted":366,"reviews__platform_label":388,"contacts__address_street":110,"documents__transfer_text":389,"header__mobile_menu_aria":390,"hero__scroll_button_aria":391,"accommodation__title_blue":392,"accommodation__title_gold":393,"documents__transfer_badge":192,"documents__transfer_title":394,"seo__default__description":395,"accommodation__blocked_note":396,"accommodation__not_accepted":397,"accommodation__blocked_title":410,"accommodation__accepted_title":411,"accommodation__blocked_subtitle":412,"accommodation__accepted_subtitle":413},"38a338d6-d266-462d-a4bb-781beb051551","site_content",[14,19,23,27,31,35,39],{"a":15,"q":16,"_uid":17,"component":18},"«Доброе сердце» — Астанадағы жеке қарттар үйі. Республика даңғылындағы мекен-жайымызда қарт адамдарға тәулік бойы кәсіби күтім, медициналық қолдау және 4 рет тамақтандыру ұсынамыз.","«Доброе сердце» пансионаты дегеніміз не және ол қайда орналасқан?","4473hcnjq1rn2fob3v93dq","qa_item",{"a":20,"q":21,"_uid":22,"component":18},"Апталық медициналық тексеру, тәулік бойы медбике кезекшілігі, 4 рет теңгерімді тамақтандыру, күнделікті серуен, дәрі-дәрмек бақылауы, гигиеналық процедуралар, психологиялық қолдау және туыстармен онлайн кездесулер кіреді.","Тұруға қандай қызметтер кіреді?","ub56n4zilwokhkfi04ab1a",{"a":24,"q":25,"_uid":26,"component":18},"Дені сау қарт адамдар, төсек тартып жатқан науқастар, деменциясы және Альцгеймер ауруы бар адамдар, инсульт, инфаркт, операция және сынықтан (соның ішінде жамбас сүйегінің мойнынан) кейінгі адамдарды қабылдаймыз. Қарсы көрсеткіштер: онкологияның 4-ші сатысы, В\u002FС гепатиті, жұқпалы аурулар, айқын агрессия.","Пансионатқа кімдерді қабылдайсыздар?","p6pxkj87l8bu1fa5427f0m",{"a":28,"q":29,"_uid":30,"component":18},"Баға денсаулық жағдайына, орналастыру форматына және күтім көлеміне байланысты жеке есептеледі. +38 096 146 29 10 нөміріне қоңырау шалыңыз — сізге жеке баға есептейміз.","Астанадағы пансионатта тұру қанша тұрады?","woretf7etjd8aogldji1g",{"a":32,"q":33,"_uid":34,"component":18},"Паспорт көшірмелері (туысы мен болашақ тұрғынның), тұрғынның жазбаша келісімі, медициналық карта, психиатр анықтамасы (қажет болса). Сұрақ болса — қоңырау шалыңыз, көмектесеміз.","Қабылдану үшін қандай құжаттар қажет?","5148rhm4n6sr5q3fte6xb",{"a":36,"q":37,"_uid":38,"component":18},"Иә, үш формат ұсынамыз: қысқа мерзімді (тәуліктік немесе кез келген мерзімге), күндізгі (күндіз бізде, түнде үйде) және тұрақты тәуліктік орналастыру.","Күндізгі немесе қысқа мерзімді орналастыру бар ма?","aeoq0pkp99m218hk1zvjeji",{"a":40,"q":41,"_uid":42,"component":18},"Иә, тұрғынды пансионатқа жеке жеткізуді ұйымдастырамыз. Денсаулық жағдайын ескереміз, жайлы көлік және ілеспе қамтамасыз етеміз. Астана және облыс бойынша жұмыс істейміз.","Трансфер ұйымдастырасыздар ба?","r0p9j1vnkx488x3vg93my","Басты баннер","Бағаны білу",[46,51,55,59,63,67],{"_uid":47,"href":48,"label":49,"component":50},"ksvgwt8v4gat4k5caig6q","#about","Біз туралы","link_item",{"_uid":52,"href":53,"label":54,"component":50},"f8333c2rkv4ed4qi1rwdj","#services","Қызметтер",{"_uid":56,"href":57,"label":58,"component":50},"1yx5d4kqubo806t34fao6","#accommodation","Тұру",{"_uid":60,"href":61,"label":62,"component":50},"5zy12prjkbjm88i8k4xw5d","#documents","Құжаттар",{"_uid":64,"href":65,"label":66,"component":50},"8a65k0qvomdnt8kgjw52d","#price","Баға",{"_uid":68,"href":69,"label":70,"component":50},"z6lopllwd7m2em61nz38","#contacts","Байланыс",[72,74,76,78,80,82],{"_uid":73,"href":48,"label":49,"component":50},"52qap0oflw72s6ffzniiw8",{"_uid":75,"href":53,"label":54,"component":50},"wvu90y9w2iomnm1h3805dn",{"_uid":77,"href":57,"label":58,"component":50},"korct3qr0xhk1f09glqx7b",{"_uid":79,"href":61,"label":62,"component":50},"62m8louje3p9vzxjtnshic",{"_uid":81,"href":65,"label":66,"component":50},"92gi88ki51emb19xsyao9g",{"_uid":83,"href":69,"label":70,"component":50},"26astey10s2hzl9zknmsdb","Қарттар пансионатын таңдағанда, шынайы қамқорлық көрсетілетін орынды табу өте маңызды. «Доброе сердце» пансионатында әр адам әрқашан бірінші орында.","Қарттар үйі туралы көзқарасыңызды өзгерту үшін пансионатымызға келіп, тұрғындармен және қызметкерлермен жеке сөйлесуге шақырамыз.","Жиі қойылатын сұрақтар","🇰🇿 Қазақстан, Астана қ.",[89,93,96,99],{"_uid":90,"text":91,"component":92},"hmql3dduf76cb3lfjh77q","Бізге қоңырау шалыңыз","text_item",{"_uid":94,"text":95,"component":92},"3kkd6o5892qloz4b62p2n","Бос орындардың бар-жоғын біліңіз",{"_uid":97,"text":98,"component":92},"s5lwh8kuyo9vnyw9ka2o2d","Жеке тұру шарттарын талқылаңыз",{"_uid":100,"text":101,"component":92},"v9f9uvsj5tdjb50g3eww09","Келісімшартқа қол қойып, құжаттарды рәсімдеңіз","Көбірек пікір ашу","Пансионатта тұру туралы ең маңызды сұрақтар — адал және толық жауаптармен.","Келесі фото","Алдыңғы фото","Өзекті бағалар мен пікірлер","Қоңырау шалу","Пансионат «Доброе сердце». Барлық құқықтар қорғалған.","Қазір өтінім қабылдаймыз","Республика даңғылы","Жабу","Біздің пансионат - әрбір тұрғын өзін үйдегідей сезінетін орын: жылы атмосфера, білікті мамандар және белсенді өмір.","Бізбен байланысу",[115,118,121],{"_uid":116,"text":117,"component":92},"p4wwounsmorobpd41lshp","Әр тұрғынға сапалы әрі кәсіби күтім көрсету",{"_uid":119,"text":120,"component":92},"gydclvzcd3mntdbux3nyh","Тұруға және демалуға жайлы орта қалыптастыру",{"_uid":122,"text":123,"component":92},"bz3nuvbw2r50uqcx1f9bd7","Әр адамға жеке көңіл бөліп, қамқорлық таныту","Жұмыс уақыты","Телефон","Сұрақтарыңызға","жауаптар","Қарттарға арналған пансионат",[130,141,148,155,162,169,176,183],{"alt":131,"src":132,"_uid":139,"component":140},"Бағаналы пансионаттың жасыл ауласы мен қасбеті",{"id":133,"alt":134,"name":135,"focus":134,"title":134,"filename":136,"copyright":134,"fieldtype":137,"is_external_url":138},182924535437703,"","img.webp","https:\u002F\u002Fs3.amazonaws.com\u002Fa.storyblok.com\u002Ff\u002F292836177534295\u002F210766\u002F1a07daceb3\u002Fimg.webp","asset",false,"t82ar6es8pfxko2qngj5fn","image_item",{"alt":142,"src":143,"_uid":147,"component":140},"Ашық террасасы бар пансионат ғимараты",{"id":144,"alt":134,"name":145,"focus":134,"title":134,"filename":146,"copyright":134,"fieldtype":137,"is_external_url":138},182924537973128,"img1.webp","https:\u002F\u002Fs3.amazonaws.com\u002Fa.storyblok.com\u002Ff\u002F292836177534295\u002F319584\u002F6fc915f115\u002Fimg1.webp","g63abos68387eq67pw4uk5",{"alt":149,"src":150,"_uid":154,"component":140},"Хрусталь шамы бар кең жатын бөлме",{"id":151,"alt":134,"name":152,"focus":134,"title":134,"filename":153,"copyright":134,"fieldtype":137,"is_external_url":138},182924540565897,"img2.webp","https:\u002F\u002Fs3.amazonaws.com\u002Fa.storyblok.com\u002Ff\u002F292836177534295\u002F133856\u002F0d92004f8d\u002Fimg2.webp","91d3ljhk0tv3582kvw9q1p",{"alt":156,"src":157,"_uid":161,"component":140},"Шам мен диваны бар кіреберіс холл",{"id":158,"alt":134,"name":159,"focus":134,"title":134,"filename":160,"copyright":134,"fieldtype":137,"is_external_url":138},182924543043978,"img3.webp","https:\u002F\u002Fs3.amazonaws.com\u002Fa.storyblok.com\u002Ff\u002F292836177534295\u002F120202\u002Ffb8bc0487f\u002Fimg3.webp","0maz2g7i3hxhv4z5bp3cn7",{"alt":163,"src":164,"_uid":168,"component":140},"Камині және жайлы креслолары бар бөлме",{"id":165,"alt":134,"name":166,"focus":134,"title":134,"filename":167,"copyright":134,"fieldtype":137,"is_external_url":138},182924545427851,"img4.webp","https:\u002F\u002Fs3.amazonaws.com\u002Fa.storyblok.com\u002Ff\u002F292836177534295\u002F179728\u002Ffdbdd8e407\u002Fimg4.webp","er6ez6jt0tr9pmuuxknqp",{"alt":170,"src":171,"_uid":175,"component":140},"Үлкен ас үстелі бар ас үй",{"id":172,"alt":134,"name":173,"focus":134,"title":134,"filename":174,"copyright":134,"fieldtype":137,"is_external_url":138},182924547987852,"img5.webp","https:\u002F\u002Fs3.amazonaws.com\u002Fa.storyblok.com\u002Ff\u002F292836177534295\u002F177510\u002F0fa81f8870\u002Fimg5.webp","wxznjv85f2a79p7no041ys",{"alt":177,"src":178,"_uid":182,"component":140},"Жарық бөлме, паркет және ақ жиһаз",{"id":179,"alt":134,"name":180,"focus":134,"title":134,"filename":181,"copyright":134,"fieldtype":137,"is_external_url":138},182924550498701,"img6.webp","https:\u002F\u002Fs3.amazonaws.com\u002Fa.storyblok.com\u002Ff\u002F292836177534295\u002F132968\u002Ff7a87670c0\u002Fimg6.webp","da9vev5xfh8d8bupd1j745",{"alt":184,"src":185,"_uid":189,"component":140},"Мәрмәр плиткасы бар жуыну бөлмесі",{"id":186,"alt":134,"name":187,"focus":134,"title":134,"filename":188,"copyright":134,"fieldtype":137,"is_external_url":138},182924553238926,"img7.webp","https:\u002F\u002Fs3.amazonaws.com\u002Fa.storyblok.com\u002Ff\u002F292836177534295\u002F234648\u002F046b2ef5c3\u002Fimg7.webp","sgdjpugcq6sez2tl1v2a58","Жекелей","Баға тұру ұзақтығын, денсаулық жағдайын және бөлме санатын ескере отырып жеке есептеледі.","24\u002F7 қолдау","Жеке тәсіл",[195,200,204,208,212,216,220,224],{"_uid":196,"title":197,"component":198,"description":199},"bzzogie0584crj5pvevk57","Медициналық күтім","service_item","Апта сайын медициналық тексеру жүргізіледі. Күн сайын әр тұрғынның қан қысымы, пульсі және дене температурасы бақыланады.",{"_uid":201,"title":202,"component":198,"description":203},"1pmwaqad262p8optyr4rsh","Тәулік бойы медбике","Қызметкерлер 24\u002F7 бақылау жүргізеді. Шұғыл көмек көрсетуге арналған медициналық пост бар.",{"_uid":205,"title":206,"component":198,"description":207},"xenltjpffcnc460m8glir","Теңгерімді тамақтану","Күніне бес рет тамақтану: диеталық талаптар мен әр тұрғынның жеке қалауына сай мәзір.",{"_uid":209,"title":210,"component":198,"description":211},"rxdkwejjkn3kvnhcego6","Күнделікті серуен","Жақсы көңіл-күй мен белсенділікті сақтау үшін персоналмен бірге таза ауада күнделікті серуен.",{"_uid":213,"title":214,"component":198,"description":215},"i9m7j3w2pkhroqo1bb11sc","Дәрі-дәрмек бақылауы","Дәрігер тағайындаған дәрілерді уақытылы беру және қабылдауды күнделікті бақылау.",{"_uid":217,"title":218,"component":198,"description":219},"iqw92bwd9xdhvpwlbcxq3u","Туыстармен онлайн кездесу","Skype, Viber, Facebook Messenger арқылы туыстармен бейнеқоңыраулар ұйымдастырылады.",{"_uid":221,"title":222,"component":198,"description":223},"4xd386md6fqp5fvp1lvsx","Гигиеналық күтім","Гигиеналық процедуралар, қозғалысқа көмек және жатын науқастарды кәсіби түрде тамақтандыру.",{"_uid":225,"title":226,"component":198,"description":227},"6v5jlirutydpbkyq7kw5se","Жеке назар","Денсаулықты тұрақты бақылау, психологиялық қолдау және әр тұрғынға жеке тәсіл.","Мұқият алып жүру","Жайлы көлік","Астана және облыс",[232,235,238,241],{"_uid":233,"text":234,"component":92},"2qbq2cvc9bmsvg1q7sn88","Паспорт көшірмелері (келісімшарт жасаушы туыс және болашақ тұрғын)",{"_uid":236,"text":237,"component":92},"9iwskd58wbow1dta1ws2","Болашақ тұрғынның жазбаша келісімі",{"_uid":239,"text":240,"component":92},"ykzdtyd2f4fjq4mrt8fy1","Медициналық карта және дәрігер қорытындылары",{"_uid":242,"text":243,"component":92},"h9ry9r7hqggihzaslsx54","Психиатр анықтамасы (қажет болған жағдайда)","Фотогалерея","Басты навигация","Күніне 4 рет тамақтану","Тәулік бойы күтім","Жайлылық пен қамқорлық","жақындарыңыз үшін","«Доброе сердце» пансионатындағы тұру құны әр тұрғын үшін жеке есептеледі.","Пікірлер",{"id":253,"alt":134,"name":254,"focus":134,"title":134,"filename":255,"copyright":134,"fieldtype":137,"is_external_url":138},182924524427652,"care.webp","https:\u002F\u002Fs3.amazonaws.com\u002Fa.storyblok.com\u002Ff\u002F292836177534295\u002F176918\u002F11e364ead5\u002Fcare.webp",{"id":257,"alt":134,"name":258,"focus":134,"title":134,"filename":259,"copyright":134,"fieldtype":137,"is_external_url":138},182924529834373,"hugs.webp","https:\u002F\u002Fs3.amazonaws.com\u002Fa.storyblok.com\u002Ff\u002F292836177534295\u002F221774\u002F47395d29cc\u002Fhugs.webp","Біздің миссиямыз","— сіздің тыныштығыңыз бен амандығыңыз","Мекенжай","Навигация","Пансионатқа жазылу","Төмен сырғытыңыз","Жеке есеп","Тұру құны","Мөлдір баға саясаты","әр отбасы үшін","Тәуелсіз платформалардағы пансионат туралы пікірлерді қарап, бізді таңдаған отбасылардың әсерімен танысыңыз.","Біздің қызметтер","Өтінім қалдыру",{"id":274,"alt":134,"name":275,"focus":134,"title":134,"filename":276,"copyright":134,"fieldtype":137,"is_external_url":138},182924532914566,"heart.webp","https:\u002F\u002Fs3.amazonaws.com\u002Fa.storyblok.com\u002Ff\u002F292836177534295\u002F256556\u002F272ebcce6c\u002Fheart.webp","Жыл тәжірибесі","Қоңырау шалыңыз немесе өтінім қалдырыңыз - біз сізге мүмкіндігінше жылдам жауап береміз.","Нақтылау","Тәулік бойы, аптасына 7 күн","Қоңырау шалыңыз немесе өтінім қалдырыңыз - кеңесшіміз барлық сұрағыңызға жауап береді.","Пансионатымыз қарт адамдарға жайлы тұру, белсенді өмір салты және толыққанды демалысқа жағдай жасайды.","Доброе сердце пансионатының орналасуы","Пансионатқа қабылдау үшін төмендегі құжаттар қажет. Сұрақ туындаса, бізге қоңырау шалыңыз.","«Доброе сердце» жеке пансионаты Астана қаласында қарт адамдарға тәулік бойы кәсіби күтім көрсетеді.","Жұмыс режимі:",[288,290,292,294,296,298,300,302],{"_uid":289,"text":131,"component":92},"fea34vjuhjaa7s8wil3th4",{"_uid":291,"text":142,"component":92},"t9fbtbhgnof60njmmwk3pg",{"_uid":293,"text":149,"component":92},"ukm78atvfncsfudfckw7u",{"_uid":295,"text":156,"component":92},"6srom2mly43z4jif42k11",{"_uid":297,"text":163,"component":92},"rstaq6t0rrra9s2t58uh4c",{"_uid":299,"text":170,"component":92},"oukanmfk5zi83ibvx1i1",{"_uid":301,"text":177,"component":92},"cgxuwtc7cxhzzzw84yn0us",{"_uid":303,"text":184,"component":92},"jes2gm4deubudo06gwqb6o","Фотосуретті ашу:","Біздің","жайлы пансионатқа көз жүгіртіңіз","Толығырақ білу","Қарау","Бізге сенеді","туыстар мен жақындар","Доброе сердце – қарт адамдарға арналған пансионат Астанада","Тегін","Қызметтер бойынша сұрақтарыңыз бар ма?","Тәулік бойы жұмыс режимі","Күн сайын, 24 \u002F 7","Тәулік бойы, демалыссыз","Бізбен","бүгін хабарласыңыз","позиция",[321,324,327,330],{"_uid":322,"text":323,"component":92},"7q4t00iac63dh5xln9yxv","Тұру ұзақтығы",{"_uid":325,"text":326,"component":92},"pz8m89ophhc9c7gefs8xu","Тұрғынның денсаулық жағдайы",{"_uid":328,"text":329,"component":92},"tfhgxfqy3qt4sypcrpz59l","Тұру бөлмесінің санаты",{"_uid":331,"text":332,"component":92},"2obr6fe7oh51fq6no5hz94","Қажетті күтім көлемі","Кешенді күтім","қамқорлық пен сүйіспеншілікпен","Жоғарыға","Құжаттар тізімі","Қажетті құжаттар","қабылдау үшін","Тұру нұсқалары",[341,347,352,357],{"_uid":342,"title":343,"subtitle":344,"component":345,"description":346},"ktu3gwtk1nkoq1fpiqm9aq","Қысқа мерзімді орналастыру","Тәуліктік немесе кез келген мерзімге","accommodation_option","Жақыныңызды тәуліктік немесе өзіңізге ыңғайлы кез келген мерзімге орналастыра аласыз.",{"_uid":348,"title":349,"subtitle":350,"component":345,"description":351},"yz9enfa7y9b479i5y1r9ly","Күндізгі орналастыру","Күндіз бізде, түнде үйде","Қажет болса, жақыныңызды күндізге қалдырып, кешке үйге алып кете аласыз.",{"_uid":353,"title":354,"subtitle":355,"component":345,"description":356},"jq2y11epo6l51amtt6vla","Тәулік бойы орналастыру","Толық кәсіби күтім","Егер жақыныңызға тұрақты күтім қажет болса, оны тәулік бойы өз мойнымызға аламыз.",{"_uid":358,"title":359,"subtitle":360,"component":345,"description":361},"wnubjui8kukbsfnx45q4","Науқастар мен мүгедектігі бар адамдарға 24\u002F7 күтім","Төсек тартып жатқан және деменциясы бар адамдарға күтім","Білікті медбике мен күтуші тәулік бойы күтім көрсетеді: тамақтандыру, гигиена, қозғалысқа көмек.","Қазақстан, Астана қ.","Адамдарға деген қамқорлықпен жасалды","Мәзірді ашу","пансионат, қарт адамдарға күтім, қарттар үйі, медициналық күтім, 24\u002F7 күтім, Астана, Доброе сердце, ұзақ уақыт күтім, күндізгі стационар, реабилитация, қарт адамдар, қозғалысы шектеулі адамдар, сенімді қызмет",[367,370,373,376,379,382,385],{"_uid":368,"text":369,"component":92},"nqyooqff2on468b857le1p","Дені сау егде жастағы адамдар",{"_uid":371,"text":372,"component":92},"etw5dmqxvzowlsnvwe907n","Төсек тартып жатқан егде жастағы науқастар",{"_uid":374,"text":375,"component":92},"my7r4yzuoqgouh79vprsda","Жарақаттан және сынықтан кейінгі адамдар",{"_uid":377,"text":378,"component":92},"eameqaxi5id2jk5shpnrhn","Инсульт немесе инфаркттан кейінгі адамдар",{"_uid":380,"text":381,"component":92},"gqatefb5s6b1wktbp89kzhh","Альцгеймер ауруы бар адамдар",{"_uid":383,"text":384,"component":92},"xm1f2c60engqfxujvaubkh","Қарттық деменциясы бар егде жастағы адамдар",{"_uid":386,"text":387,"component":92},"269ivgf1ioz3nxe5c3wwc","Операциядан кейінгі егде жастағы адамдар","Платформа","Қажет болса, тұрғынды пансионатқа қауіпсіз әрі жайлы жеткізуді ұйымдастырамыз.","Мобильді мәзір","Төменге сырғыту","Ыңғайлы","тұру форматын таңдаңыз","Жеке трансфер","«Доброе сердце» пансионаты қарт адамдарға күн бойы күтім, медициналық қолдау, жайлы тұрмыс және сенімді қамқорлық ұсынады.","* Өкінішке қарай, аталған жағдайларда мамандандырылған көмек көрсете алмаймыз. Нақтылау үшін қоңырау шалыңыз.",[398,401,404,407],{"_uid":399,"text":400,"component":92},"icue9kjuic81up6l7ag1h6","Онкологиялық аурудың 4-сатысы",{"_uid":402,"text":403,"component":92},"8w0qbjnpj1fca8yxdr56km","Гепатит B немесе C",{"_uid":405,"text":406,"component":92},"049eb65j6jxl22ik6vu2x78","Жұқпалы аурулар",{"_uid":408,"text":409,"component":92},"u347ztc3b29i31zjcqdg","Айқын агрессивті мінез-құлық","Қарсы көрсетілімдер","Біз кімдерді қабылдаймыз","Мамандандырылған көмекті қажет ететін жағдайлар","Жағдайлар мен диагноздардың толық тізімі","kz",null,0,[],"14c76d58-fc9a-4ebe-ae65-980333855949","2026-06-01T21:59:40.615Z","default",[],1780587824079]